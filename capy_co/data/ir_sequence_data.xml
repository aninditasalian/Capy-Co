
<odoo>
    <record id="seq_capy_order" model="ir.sequence">
        <field name="name">CapyCo Order Sequence</field>
        <field name="code">capy.order</field>
        <field name="prefix">#%(month)s</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
        <field name="use_date_range">True</field>
    </record>

    <record id="seq_capy_purchase_order" model="ir.sequence">
        <field name="name">CapyCo Purchase Order Sequence</field>
        <field name="code">capy.purchase.order</field>
        <field name="prefix">#%(month)s</field> 
        <field name="padding">3</field>
        <field name="use_date_range">True</field>
    </record>
</odoo>