<odoo>
    <record id="capy_stock_list_view" model="ir.ui.view">
        <field name="name">capy.stock.list</field>
        <field name="model">capy.stock</field>
        <field name="arch" type="xml">
            <list decoration-danger="stock_low == True">
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="min_quantity"/>
                <field name="max_quantity"/>
                <field name="location"/>
                <field name="last_updated"/>
                <field name="stock_low"/>
            </list>
        </field>
    </record>

    <record id="capy_stock_form_view" model="ir.ui.view">
        <field name="name">capy.stock.form</field>
        <field name="model">capy.stock</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Product">
                            <field name="product_id"/>
                            <field name="location"/>
                            <field name="last_updated"/>
                        </group>
                        <group string="Stock Levels">
                            <field name="quantity"/>
                            <field name="min_quantity"/>
                            <field name="max_quantity"/>
                            <field name="stock_low"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="capy_stock_search_view" model="ir.ui.view">
        <field name="name">capy.stock.search</field>
        <field name="model">capy.stock</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id"/>
                <field name="location"/>
                <filter string="Low Stock" name="stock_low" domain="[('quantity','&lt;',min_quantity)]"/>
                <filter string="OK Stock" name="ok_stock" domain="[('quantity','&gt;',min_quantity)]"/>
            </search>
        </field>
    </record>

    <record id="capy_stock_action" model="ir.actions.act_window">
        <field name="name">Stock</field>
        <field name="res_model">capy.stock</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="capy_stock_search_view"/>
    </record>
</odoo>