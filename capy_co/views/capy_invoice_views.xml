<odoo>
    <record id="capy_invoice_list_view" model="ir.ui.view">
        <field name="name">capy.invoice.list</field>
        <field name="model">capy.invoice</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'overdue'"
                  decoration-success="state == 'paid'"
                  decoration-warning="state == 'pending'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="order_id"/>
                <field name="invoice_date"/>
                <field name="due_date"/>
                <field name="amount_paid"/>
                <field name="amount_due"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="capy_invoice_form_view" model="ir.ui.view">
        <field name="name">capy.invoice.form</field>
        <field name="model">capy.invoice</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Invoice Details">
                            <field name="name"/>
                            <field name="customer_id"/>
                            <field name="order_id"/>
                            <field name="state"/>
                        </group>
                        <group string="Dates">
                            <field name="invoice_date"/>
                            <field name="due_date"/>
                        </group>
                    </group>
                    <group string="Payment Summary">
                        <field name="amount_paid"/>
                        <field name="amount_due"/>
                    </group>
                    <notebook>
                        <page string="Payments">
                            <field name="payment_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="payment_date"/>
                                    <field name="amount"/>
                                    <field name="payment_method"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="capy_invoice_search_view" model="ir.ui.view">
        <field name="name">capy.invoice.search</field>
        <field name="model">capy.invoice</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="order_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Paid" name="paid" domain="[('state','=','paid')]"/>
                <filter string="Overdue" name="overdue" domain="[('state','=','overdue')]"/>
            </search>
        </field>
    </record>

    <record id="capy_invoice_action" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">capy.invoice</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="capy_invoice_search_view"/>
    </record>
</odoo>