<odoo>
    <record id="capy_purchase_order_list_view" model="ir.ui.view">
        <field name="name">capy.purchase.order.list</field>
        <field name="model">capy.purchase.order</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'received'"
                  decoration-danger="state == 'cancelled'"
                  decoration-warning="state == 'confirmed'">
                <field name="name"/>
                <field name="supplier_id"/>
                <field name="order_date"/>
                <field name="expected_date"/>
                <field name="state" widget="badge" 
                   decoration-info="state == 'draft'" 
                   decoration-warning="state == 'confirmed'" 
                   decoration-success="state == 'received'" 
                   decoration-danger="state == 'cancelled'"/>
                <field name="total_cost"/>
            </list>
        </field>
    </record>

    <record id="capy_purchase_order_form_view" model="ir.ui.view">
        <field name="name">capy.purchase.order.form</field>
        <field name="model">capy.purchase.order</field>
        <field name="arch" type="xml">
            <form>
            <header>
                <button name="action_confirm" 
                        type="object" 
                        string="Confirm Order" 
                        class="oe_highlight" 
                        invisible="state != 'draft'"/>

                <button name="action_received" 
                        type="object" 
                        string="Receive Products" 
                        class="oe_highlight" 
                        invisible="state != 'confirmed'"/>

                <button name="action_cancel" 
                        type="object" 
                        string="Cancel Order" 
                        invisible="state == 'cancelled'"/>

                <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,received"/>
            </header>
                <sheet>
                    <group>
                        <group string="Order Details">
                            <field name="name" string="Order ID" readonly="1" force_save="1"/>
                            <field name="supplier_id"/>
                        </group>
                        <group string="Dates">
                            <field name="order_date"/>
                            <field name="expected_date"/>
                        </group>
                    </group>
                    <group string="Summary">
                        <field name="total_cost"/>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="order_lines">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price" readonly="1" force_save="1"/>
                                    <field name="subtotal"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="product_id"/>
                                            <field name="quantity"/>
                                            <field name="unit_price"/>
                                            <field name="purchase_order_id" invisible="1"/> 
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="capy_purchase_order_search_view" model="ir.ui.view">
        <field name="name">capy.purchase.order.search</field>
        <field name="model">capy.purchase.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="supplier_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Received" name="received" domain="[('state','=','received')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state','=','cancelled')]"/>
            </search>
        </field>
    </record>

    <record id="capy_purchase_order_calendar_view" model="ir.ui.view">
        <field name="name">capy.purchase.order.calendar</field>
        <field name="model">capy.purchase.order</field>
        <field name="arch" type="xml">
            <calendar string="Deliveries" date_start="expected_date" color="supplier_id" mode="month">
                <field name="name"/>
                <field name="supplier_id"/>
                <field name="total_cost"/>
            </calendar>
        </field>
    </record>

    <record id="capy_purchase_order_action" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">capy.purchase.order</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="search_view_id" ref="capy_purchase_order_search_view"/>
    </record>
</odoo>