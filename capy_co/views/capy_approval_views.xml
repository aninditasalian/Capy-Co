<odoo>
    <record id="capy_approval_list_view" model="ir.ui.view">
        <field name="name">capy.approval.list</field>
        <field name="model">capy.approval</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-warning="state == 'pending'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <field name="approval_type"/>
                <field name="request_date"/>
                <field name="response_date"/>
                <field name="state" 
                   widget="badge" 
                   decoration-warning="state == 'pending'" 
                   decoration-success="state == 'approved'" 
                   decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="capy_approval_form_view" model="ir.ui.view">
        <field name="name">capy.approval.form</field>
        <field name="model">capy.approval</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit for Approval" 
                            class="oe_highlight" invisible="state != 'draft'"/>
                    
                    <button name="action_approve" type="object" string="Approve" 
                            class="oe_highlight" invisible="state != 'pending'"/>
                    
                    <button name="action_reject" type="object" string="Reject" 
                            invisible="state != 'pending'"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group string="Request Details">
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="manager_id"/>
                            <field name="approval_type"/>
                            <field name="state"/>
                        </group>
                        <group string="Dates">
                            <field name="request_date"/>
                            <field name="response_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reason">
                            <field name="reason"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="capy_approval_search_view" model="ir.ui.view">
        <field name="name">capy.approval.search</field>
        <field name="model">capy.approval</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="manager_id"/>
                <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state','=','rejected')]"/>
                <filter string="Discounts" name="discount" domain="[('approval_type','=','discount')]"/>
                <filter string="Refunds" name="refund" domain="[('approval_type','=','refund')]"/>
                <filter string="Expenses" name="expense" domain="[('approval_type','=','expense')]"/>
            </search>
        </field>
    </record>

    <record id="capy_approval_action" model="ir.actions.act_window">
        <field name="name">Approvals</field>
        <field name="res_model">capy.approval</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="capy_approval_search_view"/>
    </record>
</odoo>