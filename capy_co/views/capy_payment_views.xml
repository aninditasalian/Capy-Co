<odoo>
    <record id="capy_payment_list_view" model="ir.ui.view">
        <field name="name">capy.payment.list</field>
        <field name="model">capy.payment</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'confirmed'"
                  decoration-danger="state == 'failed'"
                  decoration-warning="state == 'refunded'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="invoice_id"/>
                <field name="payment_date"/>
                <field name="amount"/>
                <field name="payment_method"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="capy_payment_form_view" model="ir.ui.view">
        <field name="name">capy.payment.form</field>
        <field name="model">capy.payment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Payment Details">
                            <field name="name"/>
                            <field name="customer_id"/>
                            <field name="invoice_id"/>
                            <field name="state"/>
                        </group>
                        <group string="Transaction">
                            <field name="amount"/>
                            <field name="payment_date"/>
                            <field name="payment_method"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="capy_payment_search_view" model="ir.ui.view">
        <field name="name">capy.payment.search</field>
        <field name="model">capy.payment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="invoice_id"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Failed" name="failed" domain="[('state','=','failed')]"/>
                <filter string="Refunded" name="refunded" domain="[('state','=','refunded')]"/>
                <filter string="Cash" name="cash" domain="[('payment_method','=','cash')]"/>
                <filter string="Card" name="card" domain="[('payment_method','=','card')]"/>
            </search>
        </field>
    </record>

    <record id="capy_payment_action" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">capy.payment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="capy_payment_search_view"/>
    </record>
</odoo>