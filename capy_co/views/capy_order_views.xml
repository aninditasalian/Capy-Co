<odoo>
    <record id="capy_order_list_view" model="ir.ui.view">
        <field name="name">capy.order.list</field>
        <field name="model">capy.order</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'cancelled'"
                  decoration-success="state == 'delivered'"
                  decoration-warning="state == 'shipped'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="order_date"/>
                <field name="state" 
                    widget="badge" 
                    decoration-info="state == 'new'" 
                    decoration-warning="state in ('confirmed', 'shipped')" 
                    decoration-success="state == 'delivered'" 
                    decoration-danger="state == 'cancelled'"/>
                <field name="total_amount"/>
            </list>
        </field>
    </record>

    <record id="capy_order_form_view" model="ir.ui.view">
        <field name="name">capy.order.form</field>
        <field name="model">capy.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm Order" class="oe_highlight" invisible="state != 'new'"/>
                    
                    <button name="action_ship" type="object" string="Mark as Shipped" class="oe_highlight" invisible="state != 'confirmed'"/>
                    
                    <button name="action_deliver" type="object" string="Mark as Delivered" class="oe_highlight" invisible="state != 'shipped'"/>
                    
                    <button name="action_cancel" type="object" string="Cancel Order" invisible="state in ('delivered', 'cancelled')"/>
                    
                    <button name="action_reset_to_draft" type="object" string="Reset to New" invisible="state != 'cancelled'"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="new,confirmed,shipped,delivered"/>
                </header>
                <sheet>
                    <group>
                        <group string="Order Details">
                            <field name="name"/>
                            <field name="customer_id"/>
                            <field name="order_date"/>
                            <field name="state"/>
                        </group>
                        <group string="Summary">
                            <field name="total_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="order_lines">
                                <list>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="base_price"/>
                                    <field name="subtotal"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="capy_order_search_view" model="ir.ui.view">
        <field name="name">capy.order.search</field>
        <field name="model">capy.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="customer_id"/>
                <filter string="New" name="new" domain="[('state','=','new')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Delivered" name="delivered" domain="[('state','=','delivered')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state','=','cancelled')]"/>
            </search>
        </field>
    </record>

    <record id="capy_order_graph_view" model="ir.ui.view">
        <field name="name">capy.order.graph</field>
        <field name="model">capy.order</field>
        <field name="arch" type="xml">
            <graph string="Profits Over Time" type="line" sample="1">
                <field name="order_date" interval="month"/>
                <field name="total_margin" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="capy_order_action" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">capy.order</field>
        <field name="view_mode">list,form,graph</field>
        <field name="search_view_id" ref="capy_order_search_view"/>
    </record>
</odoo>