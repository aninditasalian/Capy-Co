<odoo>
    <record id="capy_product_action" model="ir.actions.act_window">
        <field name="name">Plushies</field>
        <field name="res_model">capy.product</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="capy_product_view_list" model="ir.ui.view">
        <field name="name">capy.product.list</field>
        <field name="model">capy.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="price"/>
                <field name="stock"/>
            </list>
        </field>
    </record>

    <record id="capy_product_view_form" model="ir.ui.view">
        <field name="name">capy.product.form</field>
        <field name="model">capy.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="price"/>
                        <field name="stock"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>